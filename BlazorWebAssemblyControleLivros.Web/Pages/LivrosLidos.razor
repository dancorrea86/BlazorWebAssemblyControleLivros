@page "/lista-livros"
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject HttpClient Http

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📚 Meus Livros Lidos</h2>
        <a href="/cadastrar-livro" class="btn btn-primary">Novo Registro</a>
    </div>

    @if (livros == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Carregando biblioteca...</p>
        </div>
    }
    else if (!livros.Any())
    {
        <div class="alert alert-warning">Nenhum livro encontrado na planilha.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover shadow-sm border">
                <thead class="table-dark">
                    <tr>
                        <th>Título</th>
                        <th>Autor</th>
                        <th>Gênero</th>
                        <th>Data Leitura</th>
                        <th>Nota</th>
                        <th>Comentários</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var livro in livros)
                    {
                        <tr>
                            <td class="fw-bold">@livro.Titulo</td>
                            <td>@livro.Autor</td>
                            <td><span class="badge bg-info text-dark">@livro.Genero</span></td>
                            <td>@(DateTime.TryParse(livro.DataLeitura?.ToString(), out var dt) ? dt.ToShortDateString() : "-")</td>
                            <td>
                                @for (int i = 0; i < 5; i++)
                                {
                                    <i class="bi @(i < livro.Avaliacao ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                                }
                            </td>
                            <td class="text-truncate" style="max-width: 200px;" title="@livro.Comentarios">
                                @livro.Comentarios
                            </td>
                            <td>
                                
                                <button class="btn btn-sm btn-outline-danger" title="Excluir" @onclick="(() => Delete(livro.id))"><i class="bi bi-trash"></i></button>
                                
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<LivroDTO>? livros;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            livros = await Http.GetFromJsonAsync<List<LivroDTO>>("api/livros");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar: {ex.Message}");
            livros = new List<LivroDTO>();
        }
    }

    private async void Delete(string ID)
    {
        try
        {
            await Http.DeleteAsync($"api/livros/{ID}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar: {ex.Message}");
            livros = new List<LivroDTO>();
        }
    }

    // DTO simples para mapear o JSON do Google (letras minúsculas conforme o Script JS)
    public class LivroDTO
    {
        [JsonPropertyName("dataRegistro")]
        public object? DataRegistro { get; set; }

        [JsonPropertyName("id")]
        public string Id { get; set; } = "";

        [JsonPropertyName("titulo")]
        public string Titulo { get; set; } = "";

        [JsonPropertyName("autor")]
        public string Autor { get; set; } = "";

        [JsonPropertyName("genero")]
        public string Genero { get; set; } = "";

        [JsonPropertyName("dataLeitura")]
        public object? DataLeitura { get; set; }

        [JsonPropertyName("avaliacao")]
        public int Avaliacao { get; set; }

        [JsonPropertyName("comentarios")]
        public string Comentarios { get; set; } = "";
    }
}